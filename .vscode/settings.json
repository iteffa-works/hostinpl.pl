{
    "files.encoding": "utf8",
    "files.eol": "\n",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "[markdown]": {
      "files.trimTrailingWhitespace": false
    },
    "[css]": {
      "editor.formatOnSave": true
    },
    "php.validate.executablePath": "C:\\OSPanel\\modules\\PHP-8.5\\php.exe",
    "terminal.integrated.defaultProfile.windows": "OSPanel",
    "terminal.integrated.profiles.windows": {
      "OSPanel": {
        "path": "${env:windir}\\System32\\cmd.exe",
        "args": ["/k", "osp project auto"],
        "icon": "server",
        "cwd": "${workspaceFolder}"
      },
      "PowerShell": {
        "source": "PowerShell",
        "icon": "terminal-powershell"
      },
      "Command Prompt": {
        "path": "${env:windir}\\System32\\cmd.exe",
        "icon": "terminal-cmd"
      }
    },
    "files.exclude": {
      "**/.cursor": false,
      "**/.sources": false,
      "**/.docs": false,
      "**/.osp": false,
      "**/.tools": false,
      "**/.vscode": false,
      "**/node_modules": false,
      "**/vendor": false,
      "**/.editorconfig": false,
      "**/AGENTS.md": false
    }
  }